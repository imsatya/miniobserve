# Copy to .env and fill in. Never commit .env.

# sqlite (default) or supabase
MINIOBSERVE_BACKEND=sqlite

# SQLite file when MINIOBSERVE_BACKEND=sqlite (default: ~/.miniobserve/logs.db)
# MINIOBSERVE_DB=

# --- Supabase (set MINIOBSERVE_BACKEND=supabase) ---
# Project URL + secret key from Supabase Dashboard → Settings → API
# Prefer the service_role key for this server (bypasses RLS). Do not expose it in the browser.
SUPABASE_URL=
SUPABASE_KEY=
# If you ever set SUPABASE_KEY to the anon key for other tools, put service_role here — it wins over SUPABASE_KEY.
# SUPABASE_SERVICE_ROLE_KEY=

# Alternative names (also read by db_supabase.py):
# PUBLIC_SUPABASE_URL=
# PUBLIC_SUPABASE_PUBLISHABLE_DEFAULT_KEY=
#
# Schema: run backend/supabase_migration.sql once in the Supabase SQL editor
# (creates mo_llm_logs, mo_run_summaries, mo_api_key_credentials + optional RPCs).

# Production (optional)
# MINIOBSERVE_ENV=production
# MINIOBSERVE_FAIL_WITHOUT_API_KEYS=1
# MINIOBSERVE_CORS_ORIGINS=https://your-domain.com
# MINIOBSERVE_PROXY_TRUSTED_HOSTS=*

# SaaS-style API keys for the dashboard and /api/log (optional).
# Format: secret:app_name — clients send only "secret" in Authorization / X-Api-Key (not secret:app_name).
# MINIOBSERVE_API_KEYS=key1:app1,key2:app2
#
# OSS local default: when MINIOBSERVE_API_KEYS is unset, non-production, no pepper, the server accepts
# optional requests with no Authorization header OR Bearer sk-local-default-key (app: default).
# Agents and the dashboard should still send Bearer sk-local-default-key (dashboard: "Default" button).
# Set to 1 to disable that implicit key (restore legacy "any Bearer maps to default" when env keys empty).
# MINIOBSERVE_DISABLE_LOCAL_DEFAULT_KEY=1
#
# Recommended when using explicit key maps: include the local default so it matches client env.
# MINIOBSERVE_API_KEYS=sk-local-default-key:default

# DB-backed API keys (minted via dashboard Settings or API). Required for mint + hash lookup.
# Use a long random string; rotating it invalidates all minted keys.
# MINIOBSERVE_API_KEY_PEPPER=

# Operator mint: POST /api/admin/api-keys with Authorization: Bearer <this>
# MINIOBSERVE_ADMIN_SECRET=

# Hosted playground only: allow POST /api/trial/api-keys (rate-limited per IP). Default off for OSS.
# MINIOBSERVE_PUBLIC_TRIAL_MINT=1
# Optional: max trial mints per client IP per sliding hour (default 8)
# MINIOBSERVE_TRIAL_MINT_PER_HOUR=8
