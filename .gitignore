*.db
*.db-journal
*.db-wal
*.db-shm

# --- Local process / server noise ---
# nohup default when redirect isn't specified
nohup.out
# Uvicorn / shell helpers (any path — not created by repo code, common manual dev)
.uvicorn.pid
.uvicorn.nohup.log
# npm / yarn / pnpm install noise (root or package dir)
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# --- OS & editors ---
.DS_Store
Thumbs.db
.idea/
*.swp
*.swo
*~
